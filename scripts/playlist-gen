#!/bin/bash
# Generate cliamp playlists for each folder in ~/Music

MUSIC_DIR="$HOME/Music"
PLAYLISTS_DIR="$HOME/.config/cliamp/playlists"
TEMP_FILE=$(mktemp)

mkdir -p "$PLAYLISTS_DIR"

echo "󰝚 Generating cliamp playlists..."

count=0

get_track_number() {
    ffprobe -hide_banner -show_format "$1" 2>/dev/null | grep "^TAG:track" | cut -d= -f2
}

EXTENSIONS="mp3 flac wav ogg aac m4a opus wma"

# Get current playlists
current_playlists=()
if [[ -d "$PLAYLISTS_DIR" ]]; then
    for f in "$PLAYLISTS_DIR"/*.toml; do
        [[ -f "$f" ]] && current_playlists+=("$(basename "$f" .toml)")
    done
fi

# Track which playlists should exist
declare -A folders_found

# Scan each folder in Music directory
for folder in "$MUSIC_DIR"/*/; do
    [[ -d "$folder" ]] || continue

    folder_name=$(basename "$folder")
    playlist_name=$(echo "$folder_name" | tr ' ' '-' | tr '[:upper:]' '[:lower:]')
    playlist_file="$PLAYLISTS_DIR/${playlist_name}.toml"

    folders_found["$playlist_name"]=1

    # Count audio files
    track_count=0
    for ext in $EXTENSIONS; do
        track_count=$((track_count + $(find "$folder" -type f -iname "*.$ext" 2>/dev/null | wc -l)))
    done

    # Start playlist - write to temp file first, then move
    {
        echo "# Generated by playlist-gen - $(date)"
        echo ""

        # Collect files with track numbers and write to temp file
        > "$TEMP_FILE"
        for ext in $EXTENSIONS; do
            while IFS= read -r file; do
                track_num=$(get_track_number "$file")
                if [[ -n "$track_num" ]]; then
                    track_num=$((10#$track_num))
                    echo "$track_num|$file" >> "$TEMP_FILE"
                fi
            done < <(find "$folder" -type f -iname "*.$ext" 2>/dev/null)
        done

        # Sort by track number (numeric) and write playlist
        if [[ -s "$TEMP_FILE" ]]; then
            while IFS= read -r entry; do
                file="${entry#*|}"
                filename=$(basename "$file")
                title="${filename%.*}"
                title_escaped=$(echo "$title" | sed 's/"/\\"/g')
                echo "[[track]]"
                echo "path = \"$file\""
                echo "title = \"$title_escaped\""
                echo ""
            done < <(sort -t'|' -n "$TEMP_FILE")
        fi
    } > "$playlist_file"

    echo "  󰄵 ${folder_name}: ${track_count} tracks"
    ((count++))
done

echo ""
echo "󰄵 Generated ${count} playlist(s) in ${PLAYLISTS_DIR}"

# Remove playlists for folders that no longer exist
removed=0
if [[ -d "$PLAYLISTS_DIR" ]]; then
    for f in "$PLAYLISTS_DIR"/*.toml; do
        [[ -f "$f" ]] || continue
        playlist_name=$(basename "$f" .toml)
        if [[ -z "${folders_found[$playlist_name]}" ]]; then
            rm -f "$f"
            ((removed++))
        fi
    done
fi

if [[ $removed -gt 0 ]]; then
    echo "  󰷾 Removed ${removed} playlist(s) for deleted folders"
fi

rm -f "$TEMP_FILE"